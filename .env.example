# GitaAI Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file

# === LLM Provider ===
# Options: "bedrock" (AWS) or "anthropic" (direct API)
LLM_PROVIDER=bedrock

# --- Option A: AWS Bedrock (recommended if you have AWS setup) ---
AWS_REGION=us-east-1
# Leave these blank to use the default AWS credential chain
# (e.g., ~/.aws/credentials, IAM role, SSO, environment vars)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Bedrock model ID:
MODEL_NAME=us.anthropic.claude-sonnet-4-20250514-v1:0

# --- Option B: Direct Anthropic API ---
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# MODEL_NAME=claude-sonnet-4-20250514

# Embeddings
VOYAGE_API_KEY=your_voyage_api_key_here

# Knowledge Graph (Neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# CORS (comma-separated origins allowed to call the API)
CORS_ORIGINS=http://localhost:3000

# Data paths (leave blank for defaults relative to project root)
# DATA_DIR=
# CHROMA_PERSIST_DIR=

# Frontend
NEXT_PUBLIC_PIPELINE_URL=http://localhost:8000
