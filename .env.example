# GitaAI Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file

# === LLM Provider ===
# Options: "groq", "google", "openrouter", "anthropic", or "bedrock"
LLM_PROVIDER=groq

# --- Option A: Groq (recommended — free, fast, reliable) ---
GROQ_API_KEY=your_groq_api_key_here
MODEL_NAME=llama-3.3-70b-versatile

# --- Option B: Google AI Studio (Gemini — free 15 RPM) ---
# LLM_PROVIDER=google
# GOOGLE_API_KEY=your_google_api_key_here
# MODEL_NAME=gemini-2.0-flash

# --- Option C: OpenRouter (multiple models, free tier unreliable) ---
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# MODEL_NAME=meta-llama/llama-3.3-70b-instruct:free

# --- Option D: AWS Bedrock ---
# LLM_PROVIDER=bedrock
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# MODEL_NAME=us.anthropic.claude-sonnet-4-20250514-v1:0

# --- Option E: Direct Anthropic API ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# MODEL_NAME=claude-sonnet-4-20250514

# Embeddings
VOYAGE_API_KEY=your_voyage_api_key_here

# Knowledge Graph (Neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# CORS (comma-separated origins allowed to call the API)
CORS_ORIGINS=http://localhost:3000

# Data paths (leave blank for defaults relative to project root)
# DATA_DIR=
# CHROMA_PERSIST_DIR=

# Frontend
NEXT_PUBLIC_PIPELINE_URL=http://localhost:8000
