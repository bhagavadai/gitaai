# GitaAI Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file

# === LLM Provider ===
# Options: "openrouter" (free models), "anthropic", or "bedrock"
LLM_PROVIDER=openrouter

# --- Option A: OpenRouter (recommended — free models available) ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
MODEL_NAME=google/gemini-2.0-flash-exp:free

# --- Option B: AWS Bedrock ---
# LLM_PROVIDER=bedrock
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# MODEL_NAME=us.anthropic.claude-sonnet-4-20250514-v1:0

# --- Option C: Direct Anthropic API ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# MODEL_NAME=claude-sonnet-4-20250514

# Embeddings
VOYAGE_API_KEY=your_voyage_api_key_here

# Knowledge Graph (Neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# CORS (comma-separated origins allowed to call the API)
CORS_ORIGINS=http://localhost:3000

# Data paths (leave blank for defaults relative to project root)
# DATA_DIR=
# CHROMA_PERSIST_DIR=

# Frontend
NEXT_PUBLIC_PIPELINE_URL=http://localhost:8000
